{
  "name": "chrtv-platform",
  "version": "1.0.9",
  "private": true,
  "description": "Carrier Haulage Real Time Visibility Platform",
  "scripts": {
    "build:css": "tailwindcss -i ./public/css/app.src.css -o ./public/css/app.css --minify",
    "postinstall": "npm install --prefix backend",
    "dev": "npm run dev --prefix backend",
    "start": "npm run start --prefix backend",
    "schema": "npm run schema --prefix backend",
    "seed": "npm run seed --prefix backend",

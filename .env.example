DB_HOST=127.0.0.1
# On Windows with AMPPS, prefer 127.0.0.1 over localhost to avoid IPv6 connection issues.
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=rtv_platform
DB_CONNECTION_LIMIT=20
DB_MAX_IDLE=10
DB_IDLE_TIMEOUT_MS=60000
DB_QUEUE_LIMIT=0
DB_CONNECT_TIMEOUT_MS=10000
DB_KEEPALIVE_INITIAL_DELAY_MS=0

HTTP_TIMEOUT_MS=15000
HTTP_SOCKET_TIMEOUT_MS=30000
HTTP_MAX_SOCKETS=100
HTTP_MAX_FREE_SOCKETS=20
HTTP_KEEPALIVE_MS=10000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
ALLOWED_ORIGIN=http://localhost:4000
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@chrtv.local
INITIAL_ADMIN_PASSWORD=change-me-now
PASSWORD_RESET_OTP_TTL_MINUTES=10
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=CHRTV Platform <no-reply@example.com>
DASHBOARD_CACHE_TTL_MS=3000
DASHBOARD_STREAM_INTERVAL_MS=5000
SERVER_KEEPALIVE_TIMEOUT_MS=65000
SERVER_HEADERS_TIMEOUT_MS=66000
SERVER_REQUEST_TIMEOUT_MS=30000

DGW_PORT=5000
DGW_API_PORT=5001
DGW_HOST=127.0.0.1
DGW_API_HOST=127.0.0.1
TS_PORT=3001
TS_HOST=127.0.0.1
AS_PORT=3002
AS_HOST=127.0.0.1
IS_PORT=3003
IS_HOST=127.0.0.1
AA_PORT=4000
DGW_MAX_CONNECTIONS=5000

TRACKING_SERVICE_URL=http://127.0.0.1:3001
ASSET_SERVICE_URL=http://127.0.0.1:3002
INTEGRATION_SERVICE_URL=http://127.0.0.1:3003
DEVICE_GATEWAY_URL=http://127.0.0.1:5001

OPTION1_COORDINATES_PATH=/coordinates
OPTION1_EVENTS_PATH=/events
OPTION1_MAX_BATCH_SIZE=200
